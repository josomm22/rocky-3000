# Copy this to .env.local and set your device's IP address.
# The dev server will proxy /api/* requests to the device.
# If the device is unreachable, the app uses built-in mock data.
#
# Find your device IP in the serial monitor output after boot:
#   "WiFi connected — IP: 192.168.x.x"
#
VITE_DEVICE_IP=192.168.1.100
