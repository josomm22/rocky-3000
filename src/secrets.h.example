/*
 * secrets.h.example — copy this file to secrets.h and fill in your credentials.
 *
 * secrets.h is gitignored and will never be committed to the repo.
 * These credentials are compiled into the firmware as fallback defaults:
 * they are used on first boot (or after a full erase) when NVS contains
 * no saved WiFi credentials.  Once the device connects successfully the
 * credentials are stored in NVS, so subsequent app-only flashes
 * (idf.py app-flash) will reconnect automatically without needing these.
 *
 * Usage:
 *   cp src/secrets.h.example src/secrets.h
 *   # edit src/secrets.h with your SSID and password
 *   idf.py build flash   # first flash — bakes credentials in as defaults
 *   idf.py app-flash     # subsequent flashes — NVS preserved, no re-setup needed
 */
#pragma once

#define DEFAULT_WIFI_SSID     ""   /* e.g. "MyHomeNetwork" */
#define DEFAULT_WIFI_PASSWORD ""   /* e.g. "hunter2"       */
